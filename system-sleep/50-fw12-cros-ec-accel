#!/usr/bin/env bash
# fw12powersave — revive the cros-ec BASE accelerometer after S3 resume.
#
# On Framework 12 (ChromeOS-EC sensor hub), the base accel goes dead (reports
# 0,0,0) after deep-sleep resume, which makes cros-ec-lid-angle return the 500
# sentinel and breaks tablet-mode detection. Hibernate resume re-probes cleanly,
# so this only acts when the base accel is actually dead.
#
# systemd runs this from /usr/lib/systemd/system-sleep/ with:
#   $1 = pre|post   $2 = suspend|hibernate|suspend-then-hibernate|...
# We act only on resume (post). Match the base accel by label, never by index
# (device numbers change across boots and across rebinds).
set -u
[ "${1:-}" = post ] || exit 0

tag=fw12-cros-ec-accel
log(){ logger -t "$tag" -- "$*"; }

base_dev() {                    # print the iio device path whose label == accel-base
    local d
    for d in /sys/bus/iio/devices/iio:device*; do
        [ "$(cat "$d/label" 2>/dev/null)" = "accel-base" ] && { printf '%s\n' "$d"; return 0; }
    done
    return 1
}

base_alive() {                  # success if the base accel reports a non-zero vector
    local d x y z
    d=$(base_dev) || return 1
    x=$(cat "$d/in_accel_x_raw" 2>/dev/null) || return 1
    y=$(cat "$d/in_accel_y_raw" 2>/dev/null) || return 1
    z=$(cat "$d/in_accel_z_raw" 2>/dev/null) || return 1
    case "$x$y$z" in (*[!0-9-]*|"") return 1;; esac
    [ $(( x*x + y*y + z*z )) -ne 0 ]
}

wait_alive() {                  # poll up to ~5s for the base accel to come back
    local i
    for i in 1 2 3 4 5; do base_alive && return 0; sleep 1; done
    return 1
}

# 0) Already fine (e.g. after hibernate)? Give it a couple seconds to settle first.
sleep 1
if wait_alive; then log "base accel alive on resume — no reset needed"; exit 0; fi

# 1) Rebind the whole sensor hub: re-probes the EC sensor stack and recreates the
#    child accel/lid-angle devices (heavier than the per-accel rebind that fails).
sh=$(ls /sys/bus/platform/drivers/cros-ec-sensorhub/ 2>/dev/null | grep -m1 '\.auto$' || true)
drv=/sys/bus/platform/drivers/cros-ec-sensorhub
if [ -n "$sh" ] && [ -w "$drv/unbind" ]; then
    log "base accel dead -> rebinding sensorhub $sh"
    printf '%s' "$sh" > "$drv/unbind" 2>/dev/null || true
    sleep 1
    printf '%s' "$sh" > "$drv/bind" 2>/dev/null || true
    if wait_alive; then log "revived via sensorhub rebind"; exit 0; fi
fi

# 2) Full module reload of the cros-ec sensor stack (leaves first, then hub).
log "still dead -> reloading cros_ec sensor modules"
modprobe -r cros_ec_lid_angle cros_ec_sensors cros_ec_sensors_core cros_ec_sensorhub 2>/dev/null || true
sleep 1
modprobe cros_ec_sensorhub 2>/dev/null || true
modprobe cros_ec_sensors cros_ec_lid_angle 2>/dev/null || true
if wait_alive; then log "revived via module reload"; exit 0; fi

log "FAILED to revive base accel after resume (manual intervention needed)"
exit 0
